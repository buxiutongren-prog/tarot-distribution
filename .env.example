# 环境变量说明（Render 部署时自动注入 DATABASE_URL）
# 本地开发时复制此文件为 .env 并填写

# PostgreSQL 连接串（Render 自动注入，本地需手动填写）
# 格式：postgresql://用户名:密码@主机:端口/数据库名
# DATABASE_URL=postgresql://postgres:password@localhost:5432/tarot_db

# JWT 密钥（生产环境请改为随机字符串）
JWT_SECRET=tarot-distribution-secret-2024

# 服务端口（Render 自动注入 PORT，本地默认 3000）
# PORT=3000

# 公网访问地址（用于生成邀请链接）
BASE_URL=http://localhost:3000
